<?xml version="1.0" encoding="utf-16"?>
 <Project Sdk="">
	<PropertyGroup>
		<OutputType>Test</OutputType>
		<StartupObject>mainTest.prg</StartupObject>
		<AssemblyName></AssemblyName>
		<ApplicationIcon></ApplicationIcon>
	    <Company>Zoo Logic S.A.</Company>
	    <NoWarn>DVFP0001,DVFP0002,DVFP0003</NoWarn>
	</PropertyGroup>
	<ItemGroup Label="VFP_Files">		
		<Content Include="..\Taspein_vie\_Base\controladordelogsadnimplant.prg" />
		<Content Include=".legacy-tests-build/**/*.prg" />
		<Content Include="Tests/**/*.prg" />
		<Content Include="*.prg" />
		<Content Include="*.h" />
		<Content Include="_dovfp_excluidos\old_entidad.prg" isExcluded="true" />
	</ItemGroup>
	<PropertyGroup>
		<!-- 
			LegacyFoxUnitTestFiles: indica a DOVFP test dÃ³nde hacer discovery de tests legacy.
			Los tests se descubren desde .legacy-tests-build/ (donde estÃ¡n los PRG transformados
			que heredan de FxuTestCaseLegacy en lugar de FxuTestCase).
			
			IMPORTANTE: transform-legacy-tests.ps1 se ejecuta como PreBuild Target y copia
			los tests desde Tests.Legacy/ a .legacy-tests-build/ aplicando la transformaciÃ³n.
		-->
		<LegacyFoxUnitTestFiles>.legacy-tests-build/**/*.prg</LegacyFoxUnitTestFiles>
	</PropertyGroup>
	<ItemGroup>
		<ProjectReference Include = "..\Organic.Sample\Organic.Sample.vfpproj" />
		<ProjectReference Include = "..\Organic.Mocks\Organic.Generator.Mocks.vfpproj" />
	</ItemGroup>
	<ItemGroup>
		<AppReference Include="dovfp.FxuLegacy.app" />
		<AppReference Include="Organic.AdnImplant.app" />
		<AppReference Include="Organic.Core.app" />
		<AppReference Include="Organic.Drawing.app" />
	</ItemGroup>

	<!-- Copiar clasesdeprueba a bin\Test -->
	<ItemGroup Label="TestAssets">
		<!-- Copiar clasesdeprueba como carpeta -->
		<None Update="clasesdeprueba">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
			<TargetPath>clasesdeprueba</TargetPath>
		</None>

		<!-- Copiar TablasDesarrollo como carpeta -->
		<None Update="..\Organic.Assets\TablasDesarrollo">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
			<TargetPath>TablasDesarrollo</TargetPath>
		</None>


		<!-- Copiar configuracionbasica como carpeta -->
		<None Update="..\Organic.Assets\configuracionbasica">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
			<TargetPath>..\configuracionbasica</TargetPath>
		</None>

		<!-- Copiar configuracionbasica como carpeta -->
		<None Update="..\Organic.Generated\adn">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
			<TargetPath>adn</TargetPath>
		</None>

		<!-- Copiar taspein\data como carpeta -->
		<None Update="..\Organic.Assets\Taspein\data">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
			<TargetPath>data</TargetPath>
		</None>
	</ItemGroup>

	<ItemGroup>
		<None Update="..\Organic.BusinessLogic\CENTRALSS\Generadores\_Base\generadordinamicomocksentidad.prg">
		<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		<TargetPath>generadordinamicomocksentidad.prg</TargetPath>
		</None>
	</ItemGroup>

	<!-- PreBuild: Transformar tests legacy antes de compilar -->
	<Target Name="TransformLegacyTests" BeforeTargets="Build">
		<Message Text="Transformando tests legacy..." Importance="high" />
		<Exec Command="powershell -ExecutionPolicy Bypass -File scripts\transform-legacy-tests.ps1" />
	</Target>
</Project>

